# Copy this file to .env and fill in your values
# For production (Render / Railway / etc.), set DATABASE_URL instead of individual vars

PORT=5000

# --- Local PostgreSQL (development) ---
DB_USER=postgres
DB_HOST=localhost
DB_NAME=colossal2
DB_PASSWORD=your_password_here
DB_PORT=5432

# --- Cloud PostgreSQL (production) ---
# Paste the connection string from Neon / Supabase / Render Postgres here
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- JWT Secrets (use strong random strings in production) ---
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_in_production_too

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
